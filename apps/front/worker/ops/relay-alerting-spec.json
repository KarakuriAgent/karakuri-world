{
  "version": "unit-32-v1",
  "required_signals": [
    "ui.snapshot.refresh_failure_total",
    "ui.r2.publish_failure_total",
    "ui.r2.publish_failure_streak",
    "ui.snapshot.generated_age_ms",
    "ui.snapshot.published_age_ms"
  ],
  "routes": [
    {
      "id": "relay-sustained-pager",
      "notification_kind": "page",
      "urgency": "sustained",
      "owner": "spectator-ui-oncall",
      "description": "Paging path for freshness, publish, or network incidents that remain broken long enough to be customer-visible."
    },
    {
      "id": "relay-ops-ticket",
      "notification_kind": "ticket",
      "urgency": "business-hours",
      "owner": "spectator-ui-ops",
      "description": "Non-paging route for data integrity gaps, schema drift, and follow-up investigation."
    }
  ],
  "alerts": [
    {
      "id": "relay-snapshot-freshness-page",
      "summary": "Page when generated or published freshness crosses stale-risk thresholds.",
      "route": "relay-sustained-pager",
      "severity": "critical",
      "page_policy": "sustained_10m",
      "clear_condition": "generated_age_ms and published_age_ms return below thresholds for 10 minutes.",
      "condition": {
        "type": "any_of",
        "conditions": [
          {
            "type": "counter",
            "metric": "ui.snapshot.refresh_failure_total",
            "match_tags": {
              "reason": [
                "boot",
                "fallback-refresh",
                "world-event",
                "manual",
                "external-request"
              ]
            },
            "min_occurrences": 3,
            "within_minutes": 15
          },
          {
            "type": "gauge",
            "metric": "ui.snapshot.generated_age_ms",
            "min_value": 60000,
            "sustained_minutes": 15
          },
          {
            "type": "gauge",
            "metric": "ui.snapshot.published_age_ms",
            "min_value": 30000,
            "sustained_minutes": 10
          }
        ]
      }
    },
    {
      "id": "relay-r2-publish-failure-page",
      "summary": "Page when repeated R2 publish failures or publish age show snapshot distribution is broken.",
      "route": "relay-sustained-pager",
      "severity": "critical",
      "page_policy": "sustained_10m",
      "clear_condition": "No publish failures for 15 minutes and published_age_ms returns below 30 seconds.",
      "condition": {
        "type": "any_of",
        "conditions": [
          {
            "type": "counter",
            "metric": "ui.r2.publish_failure_total",
            "min_occurrences": 3,
            "within_minutes": 10
          },
          {
            "type": "gauge",
            "metric": "ui.snapshot.published_age_ms",
            "min_value": 30000,
            "sustained_minutes": 10
          }
        ]
      }
    },
    {
      "id": "relay-r2-backoff-saturation-page",
      "summary": "Page when the publish retry brake reaches the 60-second ceiling and stays saturated.",
      "route": "relay-sustained-pager",
      "severity": "critical",
      "page_policy": "sustained_10m",
      "clear_condition": "publish_failure_streak drops below the 60-second-cap threshold and stays recovered for 15 minutes.",
      "condition": {
        "type": "gauge",
        "metric": "ui.r2.publish_failure_streak",
        "min_value": 5,
        "sustained_minutes": 10
      }
    }
  ],
  "readiness_checklist": [
    "r2_custom_domain_verified_at",
    "cache_rules_edge_ttl_verified_at",
    "auth_mode_smoke_verified_at",
    "r2_retry_brake_verified_at",
    "notification_receipts_verified_at",
    "synthetic_drill_receipts_verified_at",
    "preproduction_signoff_by",
    "preproduction_signoff_at"
  ]
}
