name = "karakuri-world-ui"
main = "worker/src/index.ts"
compatibility_date = "2025-04-14"

[[durable_objects.bindings]]
name = "UI_BRIDGE"
class_name = "UIBridgeDurableObject"

[[migrations]]
tag = "plan04-ui-bridge"
new_sqlite_classes = ["UIBridgeDurableObject"]

[[r2_buckets]]
binding = "SNAPSHOT_BUCKET"
# Replace these placeholder bucket names with the real R2 bucket names
# before deploying. See karakuri-world-ui/README.md#cloudflare-worker-deployment.
bucket_name = "replace-with-real-snapshot-bucket"
preview_bucket_name = "replace-with-real-snapshot-bucket-preview"
