{
  "name": "karakuri-world-monorepo",
  "version": "0.1.0",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "株式会社0235",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:server": "npm run dev -w @karakuri-world/server",
    "dev:front": "npm run dev -w @karakuri-world/front",
    "build:server": "npm run build -w @karakuri-world/server",
    "build:front": "npm run build -w @karakuri-world/front",
    "build": "npm run build:server && npm run build:front",
    "start": "npm start -w @karakuri-world/server",
    "typecheck:server": "npm run typecheck -w @karakuri-world/server",
    "typecheck:front": "npm run typecheck -w @karakuri-world/front",
    "typecheck": "npm run typecheck:server && npm run typecheck:front",
    "test:server": "npm test -w @karakuri-world/server",
    "test:front": "npm test -w @karakuri-world/front",
    "test": "npm run test:server && npm run test:front",
    "docker:up": "npm run docker:up -w @karakuri-world/server",
    "docker:down": "npm run docker:down -w @karakuri-world/server",
    "docker:logs": "npm run docker:logs -w @karakuri-world/server"
  }
}
