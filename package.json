{
  "name": "karakuri-world",
  "version": "0.1.0",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "株式会社0235",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "start": "node --env-file=.env dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:prepare": "node scripts/prepare-docker-build.mjs",
    "docker:up": "npm run docker:prepare && docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/node-ws": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "discord.js": "^14.18.0",
    "hono": "^4.7.2",
    "js-yaml": "^4.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
