  "drills": [
    {
      "id": "auth-rejected-handshake",
      "summary": "Verify auth_rejected handshakes route to the immediate pager.",
      "staging_injection": [
        "Temporarily rotate the staging relay admin credential so websocket upgrades return auth_rejected.",
        "Wait for one failed websocket connect attempt and capture the first notification receipt.",
        "Restore the valid credential immediately after the page is received."
      ],
      "expected_alert_ids": [
        "relay-ws-auth-rejected-page"
      ],
      "expected_route_ids": [
        "relay-config-pager"
      ],
      "verification": {
        "evaluation_at": "2026-07-01T00:05:00.000Z",
        "samples": [
          {
            "metric": "ui.d1.retention_run_total",
            "kind": "counter",
            "timestamp": "2026-07-01T00:00:00.000Z",
            "value": 1,
            "tags": {
              "result": "success"
            }
          },
          {
            "metric": "relay.ws.disconnect_total",
            "kind": "counter",
            "timestamp": "2026-07-01T00:04:00.000Z",
            "value": 1,
            "tags": {
              "reason": "error",
              "handshake_status": "auth_rejected"
            }
          }
        ]
      }
    },
