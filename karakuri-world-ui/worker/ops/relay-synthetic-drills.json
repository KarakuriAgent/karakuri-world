{
  "version": "unit-32-v1",
  "drills": [
    {
      "id": "polling-freshness-failure",
      "summary": "Verify that primary polling-path freshness failure alerts fire without any relay WebSocket signals.",
      "staging_injection": [
        "Block the relay worker's outbound requests to /api/snapshot so all fixed-cadence refresh attempts fail.",
        "Hold the fault long enough for generated_age_ms to cross the sustained threshold and for at least three publish failures to accumulate.",
        "Restore /api/snapshot access and confirm both freshness alerts clear."
      ],
      "expected_alert_ids": [
        "relay-r2-publish-failure-page",
        "relay-snapshot-freshness-page"
      ],
      "expected_route_ids": [
        "relay-sustained-pager"
      ],
      "verification": {
        "evaluation_at": "2026-07-01T02:20:00.000Z",
        "samples": [
          {
            "metric": "ui.d1.retention_run_total",
            "kind": "counter",
