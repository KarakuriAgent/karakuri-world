    {
      "id": "retention-cron-silence",
      "summary": "Verify retention failure and retention-silence paths before production.",
      "staging_injection": [
        "Pause or misroute the staging scheduled retention trigger so no success sample is emitted for more than two days, or replay the equivalent alert-evaluation fixture in the chosen monitoring stack.",
        "Inject one failing retention run to confirm the failure ticket path while silence is still active.",
        "Restore the cron, force one successful retention run, and record the clear notification."
      ],
      "expected_alert_ids": [
        "relay-retention-failure-ticket",
        "relay-retention-silence-page"
      ],
      "expected_route_ids": [
