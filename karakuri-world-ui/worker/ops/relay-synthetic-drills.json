      "id": "network-disconnect-sustained",
      "summary": "Verify network disconnects page only after the outage becomes sustained and then create a history-gap follow-up on recovery.",
      "staging_injection": [
        "Block staging relay egress to the upstream /ws origin while leaving the worker running.",
        "Keep the fault active past the sustained window so fixed-cadence refresh failures accumulate and generated freshness degrades.",
        "Restore network connectivity, then capture the reconnect-duration and event-gap evidence plus the notification receipts."
      ],
      "expected_alert_ids": [
        "relay-ws-network-sustained-page",
        "relay-history-gap-review-ticket",
        "relay-snapshot-freshness-page"
      ],
      "expected_route_ids": [
