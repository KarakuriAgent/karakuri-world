{
  "version": "unit-32-v1",
  "drills": [
    {
      "id": "polling-freshness-failure",
      "summary": "Verify that quiet-period fallback refresh freshness alerts fire without any relay WebSocket signals.",
      "staging_injection": [
        "Block the relay worker's outbound requests to /api/snapshot so quiet-period fallback refresh attempts fail.",
        "Hold the fault long enough for generated_age_ms to cross the sustained threshold and for at least three publish failures to accumulate.",
        "Restore /api/snapshot access and confirm both freshness alerts clear."
      ],
      "expected_alert_ids": [
        "relay-r2-publish-failure-page",
        "relay-snapshot-freshness-page"
      ],
      "expected_route_ids": [
        "relay-sustained-pager"
      ],
      "verification": {
        "evaluation_at": "2026-07-01T02:20:00.000Z",
        "samples": [
          {
            "metric": "ui.snapshot.refresh_failure_total",
            "kind": "counter",
            "timestamp": "2026-07-01T02:05:00.000Z",
            "value": 1,
            "tags": {
              "reason": "fallback-refresh"
            }
          },
          {
            "metric": "ui.r2.publish_failure_total",
            "kind": "counter",
            "timestamp": "2026-07-01T02:11:00.000Z",
            "value": 1
          },
          {
            "metric": "ui.r2.publish_failure_total",
            "kind": "counter",
            "timestamp": "2026-07-01T02:12:00.000Z",
            "value": 1
          },
          {
            "metric": "ui.r2.publish_failure_total",
            "kind": "counter",
            "timestamp": "2026-07-01T02:16:00.000Z",
            "value": 1
          },
          {
            "metric": "ui.snapshot.generated_age_ms",
            "kind": "gauge",
            "timestamp": "2026-07-01T02:05:00.000Z",
            "value": 65000
          },
          {
            "metric": "ui.snapshot.generated_age_ms",
            "kind": "gauge",
            "timestamp": "2026-07-01T02:20:00.000Z",
            "value": 95000
          },
          {
            "metric": "ui.snapshot.published_age_ms",
            "kind": "gauge",
            "timestamp": "2026-07-01T02:05:00.000Z",
            "value": 32000
          },
          {
            "metric": "ui.snapshot.published_age_ms",
            "kind": "gauge",
            "timestamp": "2026-07-01T02:20:00.000Z",
            "value": 58000
          }
        ]
      }
    },
    {
      "id": "r2-publish-retry-brake",
      "summary": "Verify persistent R2 publish failures trigger both the failure alert and the retry-brake saturation alert.",
      "staging_injection": [
        "Force staging SNAPSHOT_BUCKET writes to fail continuously (for example by revoking write access or swapping in a failing test bucket binding).",
        "Hold the fault long enough for at least three publish failures and for publish_failure_streak to reach the 60-second retry cap.",
        "Restore writes and capture the alert receipts plus the recovery clear evidence."
      ],
      "expected_alert_ids": [
        "relay-r2-backoff-saturation-page",
        "relay-r2-publish-failure-page"
      ],
      "expected_route_ids": [
        "relay-sustained-pager"
      ],
      "verification": {
        "evaluation_at": "2026-07-01T01:20:00.000Z",
        "samples": [
          {
            "metric": "ui.r2.publish_failure_total",
            "kind": "counter",
            "timestamp": "2026-07-01T01:11:00.000Z",
            "value": 1
          },
          {
