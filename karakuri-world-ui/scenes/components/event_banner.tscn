[gd_scene format=3]

[node name="EventBanner" type="PanelContainer"]
custom_minimum_size = Vector2(480, 72)

[node name="Content" type="MarginContainer" parent="."]
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 10

[node name="VBoxContainer" type="VBoxContainer" parent="Content"]

[node name="TitleLabel" type="Label" parent="Content/VBoxContainer"]
text = "Server Event"

[node name="DescriptionLabel" type="Label" parent="Content/VBoxContainer"]
text = "Description"
