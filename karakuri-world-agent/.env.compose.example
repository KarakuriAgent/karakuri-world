# Copy this file to .env.compose for Docker Compose:
# cp .env.compose.example .env.compose
# npm run docker:prepare
# docker compose --env-file .env.compose -f docker-compose.yml up --build
#
# The layout matches .env.example:
# - OPENAI_* and KARAKURI_MCP_URL are shared by all services.
# - Per-agent values use ADVENTURER_* / SCHOLAR_* prefixes.

# Shared settings
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
KARAKURI_MCP_URL=http://host.docker.internal:3000/mcp

# Adventurer agent settings
ADVENTURER_DISCORD_TOKEN=your-adventurer-discord-token
ADVENTURER_DISCORD_PUBLIC_KEY=your-adventurer-discord-public-key
ADVENTURER_DISCORD_APPLICATION_ID=your-adventurer-discord-application-id
ADVENTURER_DISCORD_MENTION_ROLE_IDS=
ADVENTURER_KARAKURI_API_KEY=karakuri_replace_me
ADVENTURER_OPENAI_MODEL=gpt-4o
ADVENTURER_BOT_NAME=adventurer
ADVENTURER_AGENT_DIR=./agents/adventurer
ADVENTURER_DATA_DIR=./data/adventurer
ADVENTURER_PORT=3101

# Scholar agent settings
SCHOLAR_DISCORD_TOKEN=your-scholar-discord-token
SCHOLAR_DISCORD_PUBLIC_KEY=your-scholar-discord-public-key
SCHOLAR_DISCORD_APPLICATION_ID=your-scholar-discord-application-id
SCHOLAR_DISCORD_MENTION_ROLE_IDS=
SCHOLAR_KARAKURI_API_KEY=karakuri_replace_me
SCHOLAR_OPENAI_MODEL=gpt-4o-mini
SCHOLAR_BOT_NAME=scholar
SCHOLAR_AGENT_DIR=./agents/scholar
SCHOLAR_DATA_DIR=./data/scholar
SCHOLAR_PORT=3102
