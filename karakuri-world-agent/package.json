{
  "name": "karakuri-world-agent",
  "version": "0.1.0",
  "description": "Discord-based karakuri-world agent powered by Vercel Chat SDK and AI SDK",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "docker:prepare": "node scripts/prepare-docker-build.mjs",
    "start": "node --env-file=.env dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "discord",
    "agent",
    "mcp",
    "karakuri-world"
  ],
  "author": "",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.25",
    "@ai-sdk/openai": "^3.0.41",
    "@chat-adapter/discord": "^4.20.1",
    "@chat-adapter/state-memory": "^4.20.1",
    "ai": "^6.0.116",
    "chat": "^4.20.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
