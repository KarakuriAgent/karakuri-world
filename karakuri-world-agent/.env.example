# Copy this file to .env for local runs:
# cp .env.example .env
# npm run dev
#
# The layout matches .env.compose.example:
# - OPENAI_* and KARAKURI_MCP_URL are shared settings.
# - The remaining values are the single-agent version of the per-agent settings.

# Shared settings
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
KARAKURI_MCP_URL=http://127.0.0.1:3000/mcp

# Agent settings
DISCORD_TOKEN=your-discord-bot-token
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_APPLICATION_ID=your-discord-application-id
DISCORD_MENTION_ROLE_IDS=
KARAKURI_API_KEY=karakuri_replace_me
OPENAI_MODEL=gpt-4o
BOT_NAME=adventurer
AGENT_DIR=./agents/adventurer
DATA_DIR=./data
PORT=3001
